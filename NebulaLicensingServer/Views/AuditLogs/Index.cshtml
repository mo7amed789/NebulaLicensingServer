@model NebulaLicensingServer.DTOs.Licenses.Responses.PagedResult<NebulaLicensingServer.DTOs.AuditLogs.Responses.AuditLogResponse>
@{
    ViewData["Title"] = "Audit Logs";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Audit Logs</h1>
        <div class="text-body-secondary">Persistent security and administration events</div>
    </div>
    <a class="btn btn-outline-secondary" href="/Dashboard">Back</a>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2">
            <div class="col-md-2"><input name="user" class="form-control" placeholder="User" /></div>
            <div class="col-md-2"><input name="action" class="form-control" placeholder="Action" /></div>
            <div class="col-md-2"><input name="license" class="form-control" placeholder="License" /></div>
            <div class="col-md-2"><input name="ipAddress" class="form-control" placeholder="IP" /></div>
            <div class="col-md-2"><input name="pageSize" type="number" min="1" max="100" value="@Model.PageSize" class="form-control" /></div>
            <div class="col-md-2 d-grid"><button class="btn btn-primary" type="submit">Search</button></div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>IP Address</th>
                        <th>License</th>
                        <th>Result</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.CreatedAt.ToString("dd MMM yyyy HH:mm:ss")</td>
                        <td>@item.Administrator</td>
                        <td>@item.Action</td>
                        <td>@item.IpAddress</td>
                        <td>@item.LicenseKey</td>
                        <td><span class="badge @(item.Result == "Success" ? "bg-success" : "bg-danger")">@item.Result</span></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
