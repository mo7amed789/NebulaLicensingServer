@model NebulaLicensingServer.ViewModels.Dashboard.LicenseListItemViewModel
@{
    ViewData["Title"] = "License Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">License Details</h1>
        <div class="text-body-secondary">@Model.LicenseKey</div>
    </div>
    <a class="btn btn-outline-secondary" href="/Dashboard">Back</a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="text-body-secondary small">License Key</label>
                <div class="fw-semibold text-break">@Model.LicenseKey</div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Status</label>
                <div>
                    <span class="badge @(Model.Status == "Activated" ? "bg-success" : Model.Status == "Expired" ? "bg-warning text-dark" : Model.Status == "Revoked" ? "bg-danger" : "bg-secondary")">
                        @Model.Status
                    </span>
                </div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Machine Hash</label>
                <div class="text-break">@(string.IsNullOrEmpty(Model.MachineHash) ? "N/A" : Model.MachineHash)</div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Device Name</label>
                <div>@(string.IsNullOrEmpty(Model.DeviceName) ? "N/A" : Model.DeviceName)</div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Activated At</label>
                <div>@(Model.ActivatedAt?.ToString("dd MMM yyyy HH:mm") ?? "Pending")</div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Expires</label>
                <div>@(Model.ExpiresAt.HasValue ? Model.ExpiresAt.Value.ToString("dd MMM yyyy HH:mm") : "Pending")</div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Last Validation</label>
                <div>@(Model.LastValidation?.ToString("dd MMM yyyy HH:mm") ?? "N/A")</div>
            </div>
            
            <div class="col-md-6">
                <label class="text-body-secondary small">Notes</label>
                <div class="text-break">@(string.IsNullOrEmpty(Model.Notes) ? "No notes available." : Model.Notes)</div>
            </div>
        </div>
    </div>
</div>