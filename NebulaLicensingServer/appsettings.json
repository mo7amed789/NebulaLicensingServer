{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=NebulaLicensingServer;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "NebulaLicensingServer",
    "Audience": "NebulaLicensingServer.Clients",
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_FOR_PRODUCTION_USE",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "LicenseSigning": {
    "OfflineGraceDays": 7
  },
  "LicenseValidation": {
    "HeartbeatIntervalSeconds": 15,
    "OfflineGraceDays": 7
  },
  "AllowedHosts": "*"
}
